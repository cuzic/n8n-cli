    "format": "biome format --write src/ tests/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
