{
  "name": "n8n-cli",
  "version": "2.0.3",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile n8n-cli",
